# ═══════════════════════════════════════════════════════════
#  AI Coding Agent — Environment Configuration (example)
# ═══════════════════════════════════════════════════════════

# Claude API key (bắt buộc để dùng LLM thật, bỏ trống = mock mode)
ANTHROPIC_API_KEY=

# Model Claude sử dụng (default: claude-sonnet-4-20250514)
# Options: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-235-20241022
CLAUDE_MODEL=claude-sonnet-4-20250514

# Mức log: DEBUG | INFO | WARN | ERROR (default: INFO)
LOG_LEVEL=INFO

# Tự động approve tất cả các bước, không hỏi y/n (default: false)
AUTO_APPROVE=false

# Thư mục output cho project được generate (default: ./output)
OUTPUT_DIR=./output
